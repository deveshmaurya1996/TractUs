{
  "name": "@tractus/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "tsx scripts/with-env.ts generate",
    "pretest": "tsx scripts/with-env.ts generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "db:generate": "tsx scripts/with-env.ts generate",
    "db:push": "tsx scripts/with-env.ts db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:force": "tsx prisma/seed.ts --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tractus/eslint-config": "workspace:*",
    "@tractus/tsconfig": "workspace:*",
    "@tractus/types": "workspace:*",
    "@tractus/validation": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^8.57.0",
    "openapi-types": "^12.1.3",
    "prisma": "^5.19.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.1"
  }
}
